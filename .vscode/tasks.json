{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake: build Debug",
      "type": "shell",
      "command": "& 'C:\\Program Files\\Microsoft Visual Studio\\18\\Insiders\\Common7\\IDE\\CommonExtensions\\Microsoft\\CMake\\CMake\\bin\\cmake.exe' --build build --config Debug",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run file-import",
      "type": "shell",
      "command": "${workspaceFolder}\\build\\file-import\\Debug\\file-import.exe",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "cmake: build Debug",
      "problemMatcher": []
    }
  ]
}
